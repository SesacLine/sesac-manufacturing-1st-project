{"id": "mt_patch_torque", "split": "clear", "msg": "아까 그 조건에서 토크만 70으로 바꾸면 위험이 어떻게 달라져?", "active_features": {"air_temperature": 300.0, "process_temperature": 311.0, "rotational_speed": 1400.0, "torque": 55.0, "tool_wear": 180.0}, "expect": {"mode": "PATCH_ACTIVE", "resolved": {"torque": 70.0, "tool_wear": 180.0}}}
{"id": "mt_use_active", "split": "clear", "msg": "같은 조건 그대로 다시 진단해줘", "active_features": {"torque": 55.0, "tool_wear": 180.0}, "expect": {"mode": "USE_ACTIVE", "changed_features": []}}
{"id": "mt_new_machine_no_merge", "split": "clear", "msg": "이건 다른 설비야. 토크 40만 있는데 진단해줘", "active_features": {"torque": 55.0, "tool_wear": 180.0}, "expect": {"mode": "CURRENT_ONLY", "resolved": {"torque": 40.0}, "must_not_reuse": ["tool_wear"]}}
{"id": "mt_refer_result", "split": "clear", "msg": "방금 진단 결과만 한 줄로 다시 요약해줘", "active_features": {"torque": 55.0}, "expect": {"mode": "REFER_ACTIVE_RESULT", "resolved": {}}}
{"id": "mt_patch_toolwear", "split": "clear", "msg": "다른 건 그대로 두고 공구마모만 250으로 가정하면?", "active_features": {"torque": 55.0, "tool_wear": 180.0}, "expect": {"mode": "PATCH_ACTIVE", "resolved": {"tool_wear": 250.0, "torque": 55.0}}}
{"id": "mt_rel_change", "split": "adversarial", "msg": "공정 온도가 지금보다 5도 더 높았으면 위험이 어떻게 돼?", "active_features": {"process_temperature": 311.0, "torque": 55.0}, "expect": {"mode": "PATCH_ACTIVE", "resolved": {"process_temperature": 316.0}}, "note": "상대 변경 → base+델타 절대값"}
{"id": "mt_remeasure", "split": "adversarial", "msg": "센서 다시 읽었더니 토크 52, 공구마모 200 나왔어. 다시 진단해줘", "active_features": {"air_temperature": 300.0, "torque": 55.0, "tool_wear": 180.0}, "expect": {"mode": "CURRENT_ONLY", "must_not_reuse": ["air_temperature"]}}
{"id": "mt_select_history", "split": "holdout", "msg": "아까 둘 중 더 위험했던 조건에서 회전속도만 1600으로 바꾸면?", "recent": [{"id": "A", "failure_types": ["TWF"], "features": {"torque": 55.0, "tool_wear": 180.0, "rotational_speed": 1400.0}}, {"id": "B", "failure_types": ["OSF"], "features": {"torque": 82.0, "tool_wear": 120.0, "rotational_speed": 1300.0}}], "expect": {"mode": "SELECT_HISTORY", "base_context_id": "B", "resolved": {"rotational_speed": 1600.0, "torque": 82.0}}}
{"id": "mt_ref_prev_sql", "split": "holdout", "msg": "방금 조회한 고장 이력 중 다운타임 큰 것만 다시 정리해줘", "prior": {"previous_sql_summary": true}, "expect": {"is_followup": true, "uses_previous_sql": true}}
{"id": "mt_ref_prev_evidence", "split": "holdout", "msg": "아까 그 문서 근거에서 점검 항목만 더 자세히", "prior": {"previous_evidence_summary": true}, "expect": {"is_followup": true, "uses_previous_evidence": true}}
{"id": "mt_multi_feature", "split": "clear", "msg": "토크 70이고 회전속도 1500으로 둘 다 바꾸면?", "active_features": {"torque": 55.0, "rotational_speed": 1400.0, "tool_wear": 180.0}, "expect": {"mode": "PATCH_ACTIVE", "resolved": {"torque": 70.0, "rotational_speed": 1500.0, "tool_wear": 180.0}}}
{"id": "mt_air_temp", "split": "clear", "msg": "공기 온도만 295로 보면?", "active_features": {"air_temperature": 300.0, "process_temperature": 311.0, "torque": 55.0}, "expect": {"mode": "PATCH_ACTIVE", "resolved": {"air_temperature": 295.0, "process_temperature": 311.0}}}
{"id": "mt_rel_add_speed", "split": "adversarial", "msg": "회전속도를 200 더 올리면?", "active_features": {"rotational_speed": 1400.0, "torque": 55.0}, "expect": {"mode": "PATCH_ACTIVE", "resolved": {"rotational_speed": 1600.0}}}
{"id": "mt_rel_half", "split": "adversarial", "msg": "토크를 절반으로 줄이면?", "active_features": {"torque": 60.0, "tool_wear": 200.0}, "expect": {"mode": "PATCH_ACTIVE", "resolved": {"torque": 30.0}}}
{"id": "mt_separate_machine", "split": "clear", "msg": "이건 별개 설비야. 토크 35만 측정했어", "active_features": {"torque": 55.0, "tool_wear": 180.0}, "expect": {"mode": "CURRENT_ONLY", "resolved": {"torque": 35.0}, "must_not_reuse": ["tool_wear"]}}
{"id": "mt_reset", "split": "clear", "msg": "처음부터 다시 할게. 토크 60으로 진단해줘", "active_features": {"torque": 55.0, "tool_wear": 180.0}, "expect": {"mode": "CURRENT_ONLY", "resolved": {"torque": 60.0}}}
{"id": "mt_ordinal_first", "split": "holdout", "msg": "첫 번째 조건 그대로 다시 진단", "recent": [{"id": "A", "features": {"torque": 55.0, "tool_wear": 180.0}}, {"id": "B", "features": {"torque": 82.0, "tool_wear": 120.0}}], "expect": {"mode": "SELECT_HISTORY", "base_context_id": "A"}}
{"id": "mt_select_by_type", "split": "holdout", "msg": "공구마모 문제였던 쪽 조건으로 다시", "recent": [{"id": "A", "failure_types": ["TWF"], "features": {"torque": 55.0}}, {"id": "B", "failure_types": ["OSF"], "features": {"torque": 82.0}}], "expect": {"mode": "SELECT_HISTORY", "base_context_id": "A"}}
{"id": "mt_conversational_why", "split": "adversarial", "msg": "왜 그렇게 위험한 거야?", "active_features": {"torque": 64.0}, "expect": {"mode": "REFER_ACTIVE_RESULT", "resolved": {}}}
{"id": "mt_carry_both", "split": "holdout", "msg": "방금 이력이랑 문서 근거 같이 묶어서 정리해줘", "prior": {"previous_sql_summary": true, "previous_evidence_summary": true}, "expect": {"is_followup": true, "uses_previous_sql": true, "uses_previous_evidence": true}}
